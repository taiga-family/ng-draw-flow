{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "declaration": true,
        "declarationMap": true,
        "inlineSources": true,
        "lib": ["dom", "es2018"],
        "outDir": "../../dist/out-tsc",
        "target": "ES2022",
        "types": [],
        "useDefineForClassFields": false
    },
    "include": ["**/*.ts"],
    "exclude": ["src/test-setup.ts", "**/*.spec.ts", "**/*.test.ts", "jest.config.ts"]
}
