{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "ng-draw-flow",
    "prefix": "df",
    "projectType": "library",
    "sourceRoot": "projects/ng-draw-flow/src",
    "tags": [
        "draw flow",
        "ng",
        "angular",
        "graph",
        "editor",
        "flow",
        "draw",
        "diagram",
        "chart",
        "graph-editor",
        "flowchart",
        "workflow",
        "node-based",
        "node-editor",
        "block-diagram",
        "data-visualization"
    ],
    "targets": {
        "build": {
            "configurations": {
                "development": {
                    "tsConfig": "tsconfig.build.json"
                },
                "production": {
                    "tsConfig": "projects/ng-draw-flow/tsconfig.lib.prod.json"
                }
            },
            "defaultConfiguration": "production",
            "dependsOn": [
                {
                    "dependencies": true,
                    "params": "forward",
                    "target": "build"
                }
            ],
            "executor": "@nx/angular:package",
            "options": {
                "project": "projects/ng-draw-flow/ng-package.json"
            },
            "outputs": ["{workspaceRoot}/dist/ng-draw-flow"]
        },
        "publish": {
            "dependsOn": [
                {
                    "params": "ignore",
                    "target": "build"
                }
            ],
            "executor": "nx:run-commands",
            "options": {
                "command": "npm publish ./dist/{projectName} --ignore-scripts"
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "options": {
                "jestConfig": "projects/ng-draw-flow/jest.config.ts"
            },
            "outputs": ["{workspaceRoot}/coverage/projects/ng-draw-flow"]
        }
    }
}
