{
    "extends": "@taiga-ui/tsconfig",
    "exclude": ["projects/**/*.spec.ts"],
    "angularCompilerOptions": {
        "strictTemplates": true,
        "extendedDiagnostics": {
            "checks": {
                "unusedStandaloneImports": "suppress"
            }
        }
    },
    "compilerOptions": {
        "baseUrl": "./",
        "outDir": "./dist/out-tsc",
        "typeRoots": [
            "node_modules/@types",
            "node_modules/@taiga-ui/tsconfig/@types",
            "node_modules/@taiga-ui/tsconfig"
        ],
        "sourceMap": true,
        "checkJs": false,
        "paths": {
            "@demo/constants": ["projects/demo/src/app/constants/index.ts"],
            "@ng-draw-flow/core": ["projects/ng-draw-flow/src/index.ts"]
        },
        "types": ["node", "ng-dev-mode"]
    }
}
