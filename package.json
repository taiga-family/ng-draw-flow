    "syncer": {
        "includePaths": [
            "./projects",
            "./package-lock.json"
        ],
        "matchPackageNames": [
            "@ng-draw-flow/*",
            "ng-draw-flow"
        ],
        "ignorePackageNames": [
            "@ng-draw-flow/ignored"
        ]
    }
